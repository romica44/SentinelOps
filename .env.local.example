# ═══════════════════════════════════════════════════════════════════
#  SentinelOps — Environment Variables
#  Copy this file to .env.local and fill in your keys.
#  Never commit .env.local to git.
# ═══════════════════════════════════════════════════════════════════

# GROQ — https://console.groq.com/keys
# Free tier: 14,400 req/day. 
GROQ_API_KEY=your-key-here

# ─── Band.ai — Per-Agent Configuration ────────────────────────────
# Incident Commander
BAND_KEY_COMMANDER=your-key-here
BAND_ID_COMMANDER=your-id-here

# Security Agent
BAND_KEY_SECURITY=your-key-here
BAND_ID_SECURITY=your-id-here

# Operations Agent
BAND_KEY_OPERATIONS=your-key-here
BAND_ID_OPERATIONS=your-id-here

# Legal Agent
BAND_KEY_LEGAL=your-key-here
BAND_ID_LEGAL=your-id-here

# Finance Agent
BAND_KEY_FINANCE=your-key-here
BAND_ID_FINANCE=your-id-here

# PR Agent
BAND_KEY_PR=your-key-here
BAND_ID_PR=your-id-here

# Executive Agent
BAND_KEY_EXECUTIVE=your-key-here
BAND_ID_EXECUTIVE=your-id-here

